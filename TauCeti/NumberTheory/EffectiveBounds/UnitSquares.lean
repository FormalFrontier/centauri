import Mathlib.NumberTheory.NumberField.Units.DirichletTheorem
import TauCeti.Algebra.Group.PowMonoidHom

/-!
# The index of powers in the unit group of a number field

For a number field `F`, every nonzero power map on the unit group has index at most
`n^[F:тДЪ]`. In particular, the subgroup of squares has index at most `2^[F:тДЪ]`:

`[O_F^├Ч : (O_F^├Ч)┬▓] тЙд 2^[F:тДЪ]`.

By Dirichlet's unit theorem `O_F^├Ч` is generated by the fundamental system (of size `rank`)
together with a generator of the finite cyclic torsion subgroup, so it is generated by
`rank + 1 тЙд [F:тДЪ]` elements; `TauCeti.index_powMonoidHom_range_le_of_closure_eq_top` then
controls the index of nonzero powers.

## Main results

* `TauCeti.NumberField.units_pow_index_le`: `[O_F^├Ч : (O_F^├Ч)тБ┐] тЙд n^[F:тДЪ]` for `n тЙа 0`.
* `TauCeti.NumberField.units_sq_index_le`: `[O_F^├Ч : (O_F^├Ч)┬▓] тЙд 2^[F:тДЪ]`.

## Provenance

Migrated from
[kim-em/erdos-unit-distance](https://github.com/kim-em/erdos-unit-distance), the
formalization of L. Alp├╢ge's disproof of the uniform-constant Erd┼Сs unit-distance
conjecture, where this bound fed an explicit class-number estimate.
-/

open NumberField NumberField.Units

namespace TauCeti.NumberField

/-- **Nonzero powers have small index in the unit group.**
`[O_F^├Ч : (O_F^├Ч)тБ┐] тЙд n^[F:тДЪ]` for `n тЙа 0`. By Dirichlet's unit theorem `O_F^├Ч` is generated
by the `rank`-element fundamental system together with a torsion generator, so
`TauCeti.index_powMonoidHom_range_le_of_closure_eq_top` bounds the index by `n^(rank+1)`,
and `rank + 1 тЙд [F:тДЪ]`. -/
theorem units_pow_index_le (F : Type*) [Field F] [NumberField F] {n : тДХ} (hn : n тЙа 0) :
    (powMonoidHom n : (ЁЭУЮ F)╦г тЖТ* (ЁЭУЮ F)╦г).range.index тЙд n ^ Module.finrank тДЪ F := by
  classical
  -- A finite generating set: the fundamental system together with a torsion generator.
  obtain тЯи╬╢, h╬╢тЯй := IsCyclic.exists_generator (╬▒ := torsion F)
  set S : Finset (ЁЭУЮ F)╦г :=
    insert (╬╢ : (ЁЭУЮ F)╦г) (Finset.image (fundSystem F) Finset.univ) with hSdef
  have h╬╢S : (╬╢ : (ЁЭУЮ F)╦г) тИИ Subgroup.closure (S : Set (ЁЭУЮ F)╦г) :=
    Subgroup.subset_closure (Finset.mem_coe.mpr (Finset.mem_insert_self _ _))
  have hgen : Subgroup.closure (S : Set (ЁЭУЮ F)╦г) = тКд := by
    refine top_le_iff.mp ?_
    rw [тЖР closure_fundSystem_sup_torsion_eq_top F, sup_le_iff]
    refine тЯиSubgroup.closure_mono ?_, ?_тЯй
    ┬╖ rw [hSdef]
      simp only [Finset.coe_insert, Finset.coe_image, Finset.coe_univ, Set.image_univ]
      exact Set.subset_insert _ _
    ┬╖ intro t ht
      obtain тЯиn, hnтЯй := Subgroup.mem_zpowers_iff.mp (h╬╢ тЯиt, htтЯй)
      have ht' : (╬╢ : (ЁЭУЮ F)╦г) ^ n = t := by
        simpa [SubgroupClass.coe_zpow] using congrArg Subtype.val hn
      rw [тЖР ht']
      exact zpow_mem h╬╢S n
  -- The index bound, and the size of the generating set.
  refine (index_powMonoidHom_range_le_of_closure_eq_top hn hgen).trans
    (Nat.pow_le_pow_right (Nat.pos_of_ne_zero hn) ?_)
  calc S.card тЙд (Finset.image (fundSystem F) Finset.univ).card + 1 := Finset.card_insert_le _ _
    _ тЙд rank F + 1 := by
        gcongr
        exact Finset.card_image_le.trans_eq (by rw [Finset.card_univ, Fintype.card_fin])
    _ тЙд Module.finrank тДЪ F := by
        have h1 := InfinitePlace.card_eq_nrRealPlaces_add_nrComplexPlaces F
        have h2 := InfinitePlace.card_add_two_mul_card_eq_rank F
        have h3 : 0 < Fintype.card (InfinitePlace F) :=
          Fintype.card_pos_iff.mpr тЯиClassical.arbitrary _тЯй
        simp only [rank]
        omega

/-- **Squares have small index in the unit group.** `[O_F^├Ч : (O_F^├Ч)┬▓] тЙд 2^[F:тДЪ]`. This is
the `n = 2` case of `TauCeti.NumberField.units_pow_index_le`, stated using Mathlib's
`Subgroup.square` for the subgroup of squares. -/
theorem units_sq_index_le (F : Type*) [Field F] [NumberField F] :
    (Subgroup.square (ЁЭУЮ F)╦г).index тЙд 2 ^ Module.finrank тДЪ F := by
  rw [TauCeti.square_eq_powMonoidHom_two_range]
  exact units_pow_index_le F (by norm_num)

end TauCeti.NumberField
